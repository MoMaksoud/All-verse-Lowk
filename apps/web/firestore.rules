rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isOrderParticipant() {
      return signedIn() && (
        resource.data.buyerId == request.auth.uid ||
        (resource.data.sellerIds is list && request.auth.uid in resource.data.sellerIds)
      );
    }

    // Server-side only collections (Admin SDK only)
    match /verification_tokens/{tokenId} {
      allow read, write: if false;
    }
    match /stripe_webhook_events/{eventId} {
      allow read, write: if false;
    }
    match /email_logs/{emailId} {
      allow read, write: if false;
    }
    match /payments/{paymentId} {
      allow read, write: if false;
    }

    // User-owned data
    match /users/{userId} {
      allow read, write: if isSelf(userId);
    }
    match /carts/{userId} {
      allow read, write: if isSelf(userId);
    }
    match /profiles/{userId} {
      allow read: if true;
      allow create, update, delete: if isSelf(userId);
    }
    match /profile_photos/{userId} {
      allow read: if true;
      allow create, update, delete: if isSelf(userId);
    }
    match /ai_usage/{userId} {
      allow read, write: if isSelf(userId);
    }

    // Listings
    match /listings/{listingId} {
      allow read: if resource.data.isActive == true || (signedIn() && resource.data.sellerId == request.auth.uid);
      allow create: if signedIn() && request.resource.data.sellerId == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.sellerId == request.auth.uid;
    }
    match /listing_photos/{listingId} {
      allow read: if true;
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.userId == request.auth.uid;
    }

    // Orders (buyer and participating sellers only)
    match /orders/{orderId} {
      allow create: if signedIn() && request.resource.data.buyerId == request.auth.uid;
      allow read, update: if isOrderParticipant();
      allow delete: if false;

      match /shipping/{shippingId} {
        allow read, write: if isOrderParticipant();
      }
    }

    // Chats (participants only)
    match /chats/{chatId} {
      function isParticipant() {
        return request.auth != null && request.auth.uid in resource.data.participants;
      }

      // Read/update/delete only if participant
      allow read, update, delete: if isParticipant();

      // Create only if creator is included in participants array
      allow create: if request.auth != null &&
                    request.resource.data.participants is list &&
                    request.auth.uid in request.resource.data.participants;

      // Messages subcollection - only participants may read; create validates sender
      match /messages/{messageId} {
        allow read: if request.auth != null &&
                     request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;

        allow create: if request.auth != null &&
                       request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants &&
                       request.resource.data.senderId == request.auth.uid;

        // Disallow updates/deletes to messages by default (tighten as needed)
        allow update, delete: if false;
      }
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
