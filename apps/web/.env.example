# Copy to .env.local and fill in values.
# Required for app: Firebase, Gemini (see main .env.local).

# --- Web / product search (optional) ---
# Get a key at https://serpapi.com/ (free tier: 100 searches/month).
# When set, search will show real results from Google Shopping and the web.
# SERPAPI_API_KEY=

# Optional fallback when SerpAPI is not set or returns no results:
# GOOGLE_CUSTOM_SEARCH_API_KEY=
# GOOGLE_CUSTOM_SEARCH_ENGINE_ID=
